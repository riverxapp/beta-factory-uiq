{
  "$schema": "https://railpack.com/schema.json",
  "deploy": {
    "aptPackages": ["git"],
    "caches": {
      "pnpm-store": {
        "directory": "/root/.local/share/pnpm/store",
        "type": "shared"
      },
      "next-cache": {
        "directory": "/app/.next/cache",
        "type": "shared"
      },
      "apt": {
        "directory": "/var/cache/apt",
        "type": "locked"
      }
    },
    "steps": {
      "run": {
        "caches": ["pnpm-store", "next-cache", "apt"],
        "commands": ["pnpm run start"]
      },
      "run:dev": {
        "caches": ["pnpm-store", "next-cache", "apt"],
        "commands": ["pnpm run dev"]
      }
    }
  }
}
